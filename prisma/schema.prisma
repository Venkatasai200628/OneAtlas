// Prisma schema — multi-tenant OneAtlas data model
// DATABASE_URL is configured in prisma.config.ts (Prisma Postgres)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("explorer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     OrgMember[]
  projects    Project[]
  deployments Deployment[]
  integrations IntegrationCredential[]
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      String   @default("member")
  email     String
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

model Project {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  prompt    String   @db.Text
  appType   String?
  status    String   @default("live")
  intent    Json?
  dataSchema Json?
  appSpec   Json?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deployments Deployment[]

  @@index([orgId])
}

model Deployment {
  id        String   @id @default(cuid())
  orgId     String
  projectId String
  subdomain String   @unique
  status    String   @default("live")
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([projectId])
}

model IntegrationCredential {
  id        String   @id @default(cuid())
  orgId     String
  provider  String
  label     String?
  encrypted Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider])
  @@index([orgId])
}
