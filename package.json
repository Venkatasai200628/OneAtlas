{
  "name": "oneatlas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:api": "next dev -p 3000",
    "build": "vite build",
    "build:api": "next build",
    "build:vercel": "node scripts/vercel-build.mjs",
    "test:edge": "node scripts/edge-case-tests.mjs",
    "test:eval": "node scripts/eval-fixture-tests.mjs",
    "preview": "vite preview",
    "start:api": "next start -p 3000",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "firebase": "^10.13.0",
    "framer-motion": "^11.3.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "next": "^15.5.18",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "react-syntax-highlighter": "^15.5.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.15",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.22.4",
    "typescript": "5.8.2",
    "vite": "^5.4.0"
  }
}
